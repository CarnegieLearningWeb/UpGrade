{
  "name": "UpGrade",
  "version": "6.4.0",
  "description": "This is a combined repository for UpGrade, an open-source platform to support large-scale A/B testing in educational applications.  Learn more at www.upgradeplatform.org",
  "main": "index.js",
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "upgrade-frontend": {
      "typescript": "~5.5.4"
    }
  },
  "private": true,
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^14.1.2",
    "@typescript-eslint/eslint-plugin": "^5.42.0",
    "@typescript-eslint/parser": "^5.42.0",
    "eslint": "^8.26.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-tsdoc": "^0.2.17",
    "husky": "^8.0.1",
    "is-ci": "^3.0.0",
    "lint-staged": "^13.0.3",
    "nps": "^5.10.0",
    "nps-utils": "^1.7.0",
    "prettier": "^2.7.1"
  },
  "scripts": {
    "prepare": "is-ci || husky install",
    "lint": "eslint --quiet -c .eslintrc.js --ext .ts './packages/{frontend,backend,types}/**/*.ts'",
    "prettier:write": "prettier --config .prettierrc './packages/{frontend,backend,types}/**/*.{ts,js,html,json,scss}' --write",
    "prettier:check": "prettier --config .prettierrc './packages/{frontend,backend,types}/**/*.{ts,js,html,json,scss}' --check",
    "backend": "yarn workspace upgrade-backend",
    "frontend": "yarn workspace upgrade-frontend"
  },
  "lint-staged": {
    "./packages/frontend/projects/upgrade/src/**/*.{ts,js,html,json,scss}": [
      "prettier --config .prettierrc --write"
    ],
    "./packages/frontend/projects/upgrade/src/**/*.ts": [
      "eslint -c .eslintrc.js --ext .ts"
    ],
    "./clientlibs/js/{src, test}/**/*.ts": [
      "prettier --config .prettierrc --write",
      "eslint -c .eslintrc.js --ext .ts"
    ],
    "./packages/types/**/*.ts": [
      "prettier --config .prettierrc --write",
      "eslint -c .eslintrc.js --ext .ts"
    ],
    "./packages/backend/{src, test}/**/*.ts": [
      "prettier --config .prettierrc --write",
      "eslint -c .eslintrc.js --ext .ts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CarnegieLearningWeb/UpGrade.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/CarnegieLearningWeb/UpGrade/issues"
  },
  "homepage": "https://github.com/CarnegieLearningWeb/UpGrade#readme"
}