          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{segmentId}}\",\n  \"name\": \"Updated Advanced Math Students\",\n  \"description\": \"Updated description for advanced math students\",\n  \"context\": \"upgrade-internal\",\n  \"type\": \"private\",\n  \"userIds\": [\"student-001\", \"student-002\", \"student-003\", \"student-004\"],\n  \"tags\": [\"math\", \"advanced\", \"updated\"],\n  \"groups\": [\n    {\n      \"groupId\": \"school-001\",\n      \"type\": \"schoolId\"\n    },\n    {\n      \"groupId\": \"class-advanced-math\",\n      \"type\": \"classId\"\n    },\n    {\n      \"groupId\": \"instructor-john\",\n      \"type\": \"instructorId\"\n    }\n  ],\n  \"subSegmentIds\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/segments",
              "host": ["{{baseUrl}}"],
              "path": ["segments"]
